<view class="page recipe-home">
  <view class="custom-back pressable" hover-class="pressing" bindtap="goBack">‹</view>

  <view class="hero">
    <view class="hero-copy">
      <view class="title">宝宝今天</view>
      <view class="title title-blue">吃什么？</view>
    </view>
    <image class="hero-image" src="/assets/generated/recipe-hero-today.png" mode="aspectFit" />
  </view>

  <view class="baby-line pressable" hover-class="pressing" bindtap="goProfile">
    <image class="avatar" src="/assets/generated/baby-chef-avatar.png" mode="aspectFit" />
    <view class="baby-name">{{profile.nickname}} · {{ageMonths}} 月龄</view>
    <view class="edit-pill">✎</view>
  </view>

  <view wx:if="{{warning}}" class="notice">{{warning}}</view>

  <view class="actions">
    <view class="action-card weekly pressable" hover-class="pressing" bindtap="goWeekly">
      <image class="action-image" src="/assets/recipes/default-meal.png" mode="aspectFit" />
      <view class="action-copy">
        <view class="action-title">一周食谱</view>
        <view class="action-desc">生成一周宝宝食谱</view>
      </view>
      <view class="action-arrow">→</view>
    </view>
    <view class="action-card random pressable" hover-class="pressing" bindtap="goRandom">
      <image class="action-image" src="/assets/ui/random-meal.png" mode="aspectFit" />
      <view class="action-copy">
        <view class="action-title">随机一餐</view>
        <view class="action-desc">不知道吃什么？抽一餐</view>
      </view>
      <view class="action-arrow">→</view>
    </view>
  </view>

  <view class="footer-note">
    <text class="shield">+</text>
    <text>家庭饮食参考，不替代专业医生建议</text>
  </view>
</view>
