<view class="page home-page">
  <view class="hero">
    <image class="brand-title" src="/assets/ui/home-brand-title.png" mode="aspectFit" />
    <view class="dot-line">
      <text></text>
      <text></text>
      <text></text>
      <view class="hero-subtitle">让宝宝吃饭更轻松</view>
      <text></text>
      <text></text>
      <text></text>
    </view>
  </view>

  <view class="entry-list">
    <view class="entry entry-recipe pressable" hover-class="pressing" bindtap="goRecipe">
      <image class="entry-image" src="/assets/recipes/default-meal.png" mode="aspectFill" />
      <view class="entry-copy">
        <view class="entry-title">好好吃饭</view>
        <view class="entry-desc">安排宝宝每日三餐</view>
      </view>
      <view class="entry-arrow">→</view>
    </view>

    <view class="entry entry-supervise pressable" hover-class="pressing" bindtap="goSupervise">
      <image class="entry-image phone-image" src="/assets/ui/home-phone-illustration.png" mode="aspectFit" />
      <view class="entry-copy">
        <view class="entry-title">乖乖吃饭</view>
        <view class="entry-desc">陪宝宝专心吃饭</view>
      </view>
      <view class="entry-arrow">→</view>
    </view>
  </view>

  <view class="home-note">
    <text class="note-dot"></text>
    <image class="baby-note-icon" src="/assets/generated/baby-note-icon.png" mode="aspectFit" />
    <text>适合 12-36 月龄宝宝三餐参考</text>
    <text class="note-dot"></text>
  </view>
</view>
