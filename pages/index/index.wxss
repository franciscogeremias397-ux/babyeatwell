.home-page {
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  height: 100vh;
  min-height: 100vh;
  padding: calc(170rpx + env(safe-area-inset-top)) 34rpx calc(72rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #ffffff 0%, #f4f9ff 78%, #eef7ff 100%);
}

.hero {
  position: relative;
  top: 28rpx;
  padding-top: 0;
  text-align: center;
  animation: fadeRise 420ms ease both;
}

.brand-title {
  width: 486rpx;
  height: 120rpx;
}

.dot-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 26rpx;
}

.dot-line text,
.note-dot {
  display: inline-block;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #77aef9;
}

.dot-line text:nth-child(2),
.dot-line text:nth-child(5) {
  background: #ffb6bc;
}

.dot-line text:nth-child(3),
.dot-line text:nth-child(6) {
  background: #8bcf9a;
}

.hero-subtitle {
  color: #6a7d99;
  font-size: 31rpx;
  font-weight: 900;
  white-space: nowrap;
}

.entry-list {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  width: 100%;
  gap: 46rpx;
  margin-top: 170rpx;
}

.entry {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
  max-width: none;
  min-height: 268rpx;
  padding: 24rpx 24rpx;
  text-align: left;
  border-radius: 42rpx;
  box-shadow: 0 18rpx 46rpx rgba(76, 118, 154, 0.1);
  animation: fadeRise 460ms ease both;
}

.entry:nth-child(2) {
  animation-delay: 70ms;
}

.entry-recipe {
  background: linear-gradient(180deg, #f4fbff 0%, #eef8ff 100%);
  border: 3rpx solid #c6e3ff;
}

.entry-supervise {
  background: linear-gradient(180deg, #fbfff6 0%, #f1ffec 100%);
  border: 3rpx solid #d1efc6;
}

.entry-image {
  flex: 0 0 218rpx;
  width: 218rpx;
  height: 218rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.7);
}

.phone-image {
  background: transparent;
  box-shadow: none;
}

.entry-copy {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.entry-title {
  color: #3487f5;
  font-size: 41rpx;
  font-weight: 900;
  line-height: 1.12;
  white-space: nowrap;
  text-shadow: 0 5rpx 0 rgba(255, 255, 255, 0.86);
}

.entry-desc {
  margin-top: 14rpx;
  color: #6a7d99;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
  white-space: nowrap;
}

.entry-supervise .entry-title {
  color: #4cb95b;
}

.entry-supervise .entry-desc {
  color: #6a7d99;
}

.entry-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 66rpx;
  width: 66rpx;
  height: 66rpx;
  margin-left: 10rpx;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
  border-radius: 50%;
  background: linear-gradient(180deg, #62a8ff 0%, #287cf0 100%);
  box-shadow: 0 12rpx 22rpx rgba(49, 128, 240, 0.22);
}

.entry-supervise .entry-arrow {
  background: linear-gradient(180deg, #7dd760 0%, #51b943 100%);
  box-shadow: 0 12rpx 22rpx rgba(80, 185, 67, 0.2);
}

.home-note {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  margin-top: 260rpx;
  color: #6a7d99;
  font-size: 27rpx;
  font-weight: 900;
  animation: fadeRise 520ms ease 120ms both;
}

.home-note .note-dot:last-child {
  background: #77aef9;
}

.baby-note-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(63, 135, 229, 0.18);
}
