<view class="page profile-page">
  <view class="profile-head">
    <view class="title">宝宝档案</view>
    <view class="subtitle">完善信息，生成更合适的食谱</view>
  </view>

  <view class="form">
    <view class="field">
      <view class="label">宝宝昵称</view>
      <input class="input" value="{{nickname}}" maxlength="10" placeholder="请输入昵称" bindinput="onNicknameInput" />
    </view>

    <view class="field">
      <view class="label">宝宝生日</view>
      <picker mode="date" value="{{birthDate}}" end="{{today}}" bindchange="onBirthDateChange">
        <view class="picker-value">{{birthDate}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">过敏食材</view>
      <checkbox-group bindchange="onAllergyChange">
        <view class="tag-grid">
          <label wx:for="{{allergyOptions}}" wx:key="standardTag" class="tag">
            <checkbox value="{{item.standardTag}}" checked="{{item.checked}}" />
            <text>{{item.label}}</text>
          </label>
        </view>
      </checkbox-group>
    </view>

    <view class="field">
      <view class="label">不吃食材</view>
      <checkbox-group bindchange="onAvoidChange">
        <view class="tag-grid">
          <label wx:for="{{avoidOptions}}" wx:key="standardTag" class="tag">
            <checkbox value="{{item.standardTag}}" checked="{{item.checked}}" />
            <text>{{item.label}}</text>
          </label>
        </view>
      </checkbox-group>
      <input class="input custom-input" value="{{customAvoid}}" placeholder="可补充一个不吃食材" bindinput="onCustomAvoidInput" />
    </view>
  </view>

  <view class="save-bar bottom-safe">
    <button class="primary-button save-button" hover-class="pressing" bindtap="save">保存档案</button>
  </view>
</view>
