<view class="page random-page">
  <view class="custom-back pressable" hover-class="pressing" bindtap="goBack">‹</view>

  <view wx:if="{{warning || emptyText}}" class="empty-card">
    <image class="empty-image" src="/assets/ui/random-meal.png" mode="aspectFit" />
    <view class="empty-title">还没抽到合适的一餐</view>
    <view class="empty-copy">{{warning || emptyText}}</view>
    <button class="detail-link retry-button pressable" hover-class="pressing" bindtap="draw">再抽一次</button>
  </view>

  <view wx:elif="{{isDrawing}}" class="draw-card">
    <view class="draw-orbit">
      <view class="draw-spark draw-spark-a"></view>
      <view class="draw-spark draw-spark-b"></view>
      <view class="draw-spark draw-spark-c"></view>
      <image class="draw-image" src="/assets/ui/random-meal.png" mode="aspectFit" />
    </view>
    <view class="draw-title">正在抽取</view>
    <view class="draw-name">{{rollingName}}</view>
  </view>

  <view wx:elif="{{recipe}}" class="result-content">
    <view class="result-card">
      <image class="recipe-image" src="{{image}}" mode="aspectFill" />
      <view class="recipe-name-pill">{{recipe.name}}</view>
      <view class="recipe-meta">{{recipe.ageMinMonths}}-{{recipe.ageMaxMonths}} 月龄 · {{mealTypesText}}</view>
      <button class="detail-link pressable" hover-class="pressing" bindtap="goDetail">查看完整做法 ›</button>
    </view>

    <view class="info-section">
      <view class="section-heading">
        <image class="section-icon" src="/assets/generated/icon-ingredients.png" mode="aspectFit" />
        <view class="section-title">食材用量</view>
      </view>
      <view class="chip-list">
        <view wx:for="{{ingredientChips}}" wx:key="*this" class="chip">{{item}}</view>
      </view>
    </view>

    <view class="info-section">
      <view class="section-heading">
        <image class="section-icon" src="/assets/generated/icon-nutrition.png" mode="aspectFit" />
        <view class="section-title">营养亮点</view>
      </view>
      <view wx:for="{{recipe.nutritionHighlights}}" wx:key="*this" class="paragraph">{{item}}</view>
    </view>

    <view class="info-section">
      <view class="section-heading">
        <image class="section-icon" src="/assets/generated/icon-caution.png" mode="aspectFit" />
        <view class="section-title">注意事项</view>
      </view>
      <view wx:for="{{recipe.cautions}}" wx:key="*this" class="paragraph">{{item}}</view>
    </view>

    <view class="random-actions bottom-safe">
      <button class="secondary-button change-button" hover-class="pressing" bindtap="draw" disabled="{{isDrawing}}">换一餐</button>
      <button class="primary-button download-button" hover-class="pressing" bindtap="downloadRecipe">下载食谱</button>
    </view>
  </view>

  <view wx:else class="empty-card">
    <image class="empty-image" src="/assets/ui/random-meal.png" mode="aspectFit" />
    <view class="empty-title">正在准备随机一餐</view>
    <view class="empty-copy">如果页面停在这里，可以点下面重新抽取。</view>
    <button class="detail-link retry-button pressable" hover-class="pressing" bindtap="draw">开始抽取</button>
  </view>
</view>
