.random-page {
  padding: calc(112rpx + env(safe-area-inset-top)) 44rpx calc(184rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #fff8ef 0%, #f8f6ef 54%, #eef8ff 100%);
}

.draw-card {
  position: relative;
  overflow: hidden;
  margin-top: 0;
  padding: 56rpx 30rpx 62rpx;
  text-align: center;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 52rpx rgba(96, 86, 70, 0.1);
  animation: fadeRise 360ms ease both;
}

.empty-card {
  position: relative;
  overflow: hidden;
  margin-top: 0;
  padding: 48rpx 34rpx 54rpx;
  text-align: center;
  border-radius: 42rpx;
  border: 2rpx solid rgba(194, 224, 255, 0.72);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 52rpx rgba(96, 86, 70, 0.1);
  animation: fadeRise 360ms ease both;
}

.empty-image {
  display: block;
  width: 260rpx;
  height: 260rpx;
  margin: 0 auto;
}

.empty-title {
  margin-top: 26rpx;
  color: #173051;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.empty-copy {
  margin-top: 18rpx;
  color: #7790ad;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.55;
}

.retry-button {
  min-width: 200rpx;
  margin-top: 30rpx;
}

.draw-orbit {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: radial-gradient(circle, #f4fff1 0%, #fff7e8 72%);
  animation: drawPulse 920ms ease-in-out infinite;
}

.draw-image {
  position: absolute;
  top: 34rpx;
  left: 34rpx;
  width: 252rpx;
  height: 252rpx;
  animation: drawWobble 420ms ease-in-out infinite;
}

.draw-spark {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ffbe4f;
  box-shadow: 0 0 0 8rpx rgba(255, 190, 79, 0.14);
}

.draw-spark-a {
  top: 38rpx;
  right: 52rpx;
}

.draw-spark-b {
  bottom: 56rpx;
  left: 44rpx;
  background: #69b6ff;
}

.draw-spark-c {
  right: 34rpx;
  bottom: 76rpx;
  background: #ff91a3;
}

.draw-title {
  margin-top: 36rpx;
  color: #58b784;
  font-size: 28rpx;
  font-weight: 900;
}

.draw-name {
  margin-top: 16rpx;
  color: #173051;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.2;
  animation: drawName 240ms ease-in-out infinite;
}

.result-card {
  position: relative;
  margin-top: 0;
  padding: 34rpx 30rpx 38rpx;
  text-align: center;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 20rpx 52rpx rgba(96, 86, 70, 0.1);
  animation: fadeRise 420ms ease 60ms both;
}

.result-content {
  padding-bottom: 10rpx;
}

.recipe-image {
  display: block;
  width: 430rpx;
  height: 430rpx;
  margin: 0 auto;
  border-radius: 28rpx;
  background: #fff8ef;
}

.recipe-name-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 430rpx;
  min-height: 78rpx;
  margin-top: 18rpx;
  padding: 0 36rpx;
  color: #173051;
  font-size: 40rpx;
  font-weight: 900;
  border-radius: 39rpx;
  background: transparent;
}

.recipe-meta {
  margin-top: 14rpx;
  color: #7a978c;
  font-size: 28rpx;
  font-weight: 700;
}

.detail-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 210rpx;
  height: 62rpx;
  margin-top: 24rpx;
  padding: 0 28rpx;
  color: #54b980;
  font-size: 27rpx;
  font-weight: 900;
  border-radius: 31rpx;
  background: #dbf8e7;
}

.info-section {
  margin-top: 28rpx;
  padding: 30rpx 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 14rpx 36rpx rgba(96, 86, 70, 0.07);
  animation: fadeRise 420ms ease 100ms both;
}

.section-heading {
  display: flex;
  align-items: center;
  min-height: 48rpx;
  gap: 14rpx;
}

.section-icon {
  flex: 0 0 46rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 28rpx;
}

.chip {
  display: flex;
  align-items: center;
  min-height: 64rpx;
  padding: 0 24rpx;
  color: #267be8;
  font-size: 28rpx;
  font-weight: 900;
  border-radius: 32rpx;
  border: 2rpx solid #b9d7ff;
  background: #f3f9ff;
}

.paragraph {
  margin-top: 24rpx;
  color: #6c8178;
  font-size: 29rpx;
  line-height: 1.7;
}

.random-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 18rpx 44rpx calc(36rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(239, 248, 255, 0) 0%, rgba(239, 248, 255, 0.94) 42%, #eff8ff 100%);
}

.change-button,
.download-button {
  flex: 0 0 auto;
  height: 76rpx;
  min-height: 76rpx;
  font-size: 27rpx;
  font-weight: 900;
  border-radius: 38rpx;
  white-space: nowrap;
}

.change-button {
  width: 202rpx;
}

.download-button {
  width: 256rpx;
  box-shadow: 0 14rpx 24rpx rgba(83, 190, 112, 0.22);
}

@keyframes drawPulse {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.035);
  }
}

@keyframes drawWobble {
  0%,
  100% {
    transform: rotate(-2deg) scale(1);
  }
  50% {
    transform: rotate(3deg) scale(1.035);
  }
}

@keyframes drawName {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4rpx);
  }
}
