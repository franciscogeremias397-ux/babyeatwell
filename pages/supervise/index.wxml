<view class="supervise-page">
  <view wx:if="{{stage === 'home'}}" class="start-screen">
    <image class="dogdan-logo" src="/assets/ui/dogdan-logo-full.png" mode="aspectFit" />
    <image class="guai-logo" src="/assets/ui/guai-title.png" mode="aspectFit" />
    <button class="call-button pressable" hover-class="pressing" bindtap="startCall">
      <image src="/assets/ui/call-button-large.png" mode="aspectFit" />
    </button>
  </view>

  <view wx:elif="{{stage === 'calling'}}" class="calling-screen">
    <image class="calling-avatar" src="/assets/ui/dogdan-logo-full.png" mode="aspectFit" />
    <view class="calling-text">正在呼叫狗蛋叔叔</view>
    <view class="calling-time">{{callingTimerText}}</view>
  </view>

  <view wx:elif="{{stage === 'done'}}" class="done-screen">
    <image class="dogdan-logo done-dogdan" src="/assets/ui/dogdan-logo-full.png" mode="aspectFit" />
    <image class="goodbye-logo" src="/assets/ui/goodbye-full.png" mode="aspectFit" />
    <button class="again-button pressable" hover-class="pressing" bindtap="reset">再来一次</button>
  </view>

  <view wx:else class="call-screen">
    <video
      wx:if="{{currentVideo}}"
      id="callVideo"
      class="call-video active"
      src="{{currentVideo}}"
      object-fit="cover"
      autoplay="{{true}}"
      loop="{{isLooping}}"
      controls="{{false}}"
      show-center-play-btn="{{false}}"
      show-fullscreen-btn="{{false}}"
      enable-progress-gesture="{{false}}"
      bindcanplay="onVideoReady"
      bindloadedmetadata="onVideoReady"
      binderror="onVideoError"
      bindended="onVideoEnded"
    />

    <view class="call-shade"></view>

    <view class="call-top">
      <view class="callee">狗蛋叔叔</view>
      <view class="call-status">{{callStatusText}}</view>
      <view class="call-meta">
        <text class="online">在线</text>
        <text class="timer">{{timerText}}</text>
      </view>
    </view>

    <view wx:if="{{stage === 'connected' && videoMode !== 'opening'}}" class="control-bar">
      <button class="control warn pressable" hover-class="pressing" bindtap="playWarning" disabled="{{isSwitching || videoMode !== 'idle'}}">
        <image class="control-image" src="/assets/ui/action-remind.png" mode="aspectFit" />
      </button>
      <button class="control praise pressable" hover-class="pressing" bindtap="playPraise" disabled="{{isSwitching || videoMode !== 'idle'}}">
        <image class="control-image" src="/assets/ui/action-praise.png" mode="aspectFit" />
      </button>
      <button class="control finish pressable" hover-class="pressing" bindtap="finishCall" disabled="{{isSwitching}}">
        <image class="control-image" src="/assets/ui/action-wave.png" mode="aspectFit" />
      </button>
    </view>
  </view>
</view>
