page {
  min-height: 100%;
  color: #203b34;
  background: #f7fbff;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  line-height: 1.2;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 44rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
}

.eyebrow {
  color: #58b784;
  font-size: 26rpx;
  font-weight: 800;
}

.title {
  margin-top: 16rpx;
  color: #203b34;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.18;
}

.subtitle {
  margin-top: 18rpx;
  color: #788b9f;
  font-size: 28rpx;
  line-height: 1.6;
}

.primary-button,
.secondary-button,
.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-button {
  color: #ffffff;
  background: linear-gradient(180deg, #6fd486 0%, #55c372 100%);
  box-shadow: 0 18rpx 32rpx rgba(83, 190, 112, 0.26);
}

.secondary-button {
  color: #46605a;
  background: #ffffff;
  border: 2rpx solid rgba(120, 139, 159, 0.16);
}

.ghost-button {
  min-height: 76rpx;
  color: #4fa66d;
  font-size: 28rpx;
}

.section-title {
  color: #203b34;
  font-size: 34rpx;
  font-weight: 900;
}

.muted {
  color: #788b9f;
}

.empty-state {
  padding: 48rpx 32rpx;
  color: #748981;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
}

.pressable {
  transition: transform 160ms ease, opacity 160ms ease;
}

.pressing {
  opacity: 0.9;
  transform: scale(0.975);
}

.soft-card {
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 48rpx rgba(65, 95, 122, 0.1);
}

.bottom-safe {
  padding-bottom: env(safe-area-inset-bottom);
}

.custom-back {
  position: fixed;
  top: calc(28rpx + env(safe-area-inset-top));
  left: 28rpx;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  color: #31506f;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 10rpx 24rpx rgba(64, 104, 144, 0.12);
}

.save-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  z-index: -1;
  opacity: 0;
  pointer-events: none;
}

@keyframes fadeRise {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes softFloat {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes pulseGlow {
  0%,
  100% {
    transform: scale(1);
    opacity: 0.42;
  }
  50% {
    transform: scale(1.08);
    opacity: 0.68;
  }
}
